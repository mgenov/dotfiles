#!/usr/bin/env bash
# tm-mobile — add Politis mobile dev windows to the agent-c worktree session.
#   • code   : nvim .
#   • dev    : android shell on top, metro + emulator side-by-side on bottom
#   • agent  : claude
#   • logs   : adb logcat -s Politis
#
# Composes with tmux-sessionizer: the session is named after the worktree
# (default `monorepo-agent-c`), so picking the worktree from sessionizer or
# running tm-mobile lands in the same session. Idempotent — only creates
# windows that don't already exist; never touches existing ones.
#
# Usage:  tm-mobile                              # ~/work/monorepo-agent-c
#         tm-mobile <name> <worktree-path>
set -e

worktree="${2:-$HOME/work/monorepo-agent-c}"
name="${1:-$(basename "$worktree" | tr '. ' '__')}"
mobile="$worktree/politis/client/mobile"

window_exists() {
    tmux list-windows -t "$name" -F '#W' 2>/dev/null | grep -Fxq "$1"
}

ensure_simple() {
    local win="$1" cmd="$2"
    window_exists "$win" && return
    tmux new-window -t "$name:" -c "$mobile" -n "$win" "$cmd"
}

ensure_dev() {
    window_exists dev && return
    tmux new-window   -t "$name:"      -c "$mobile" -n dev
    tmux split-window -t "$name:dev"   -v -l 60% -c "$mobile"
    tmux split-window -t "$name:dev.2" -h         -c "$mobile"
    tmux send-keys    -t "$name:dev.2" "npm run start" C-m
    tmux send-keys    -t "$name:dev.3" "echo 'Run: npx react-native run-android'" C-m
    tmux select-pane  -t "$name:dev.1"
}

if ! tmux has-session -t="$name" 2>/dev/null; then
    tmux new-session -ds "$name" -c "$worktree"
fi

ensure_simple code  "nvim ."
ensure_dev
ensure_simple agent "zsh -i -c x"
ensure_simple logs  "adb logcat -s Politis"
tmux select-window -t "$name:code"

[[ -z "$TMUX" ]] && exec tmux attach -t "$name"
exec tmux switch-client -t "$name"
