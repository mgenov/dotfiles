#!/usr/bin/env bash
# tm-mobile — Politis mobile dev session.
#   • code   : nvim .
#   • dev    : android shell on top, metro + emulator side-by-side on bottom
#   • agent  : claude
#   • logs   : adb logcat -s Politis
#
# Usage:  tm-mobile                 # default path: ~/work/monorepo-agent-c/politis/client/mobile
#         tm-mobile <name> <path>
set -e

path="${2:-$HOME/work/monorepo-agent-c/politis/client/mobile}"
name="${1:-mobile}"

if tmux has-session -t="$name" 2>/dev/null; then
    [[ -z "$TMUX" ]] && exec tmux attach -t "$name"
    exec tmux switch-client -t "$name"
fi

# code
tmux new-session -ds "$name" -c "$path" -n code "nvim ."

# dev: pane 1 = android shell (top), pane 2/3 = metro + emulator (bottom row)
tmux new-window   -t "$name:"     -c "$path" -n dev
tmux split-window -t "$name:dev"  -v -l 60% -c "$path"   # pane 2 below pane 1
tmux split-window -t "$name:dev.2" -h        -c "$path"  # pane 3 right of pane 2
tmux send-keys -t "$name:dev.2" "npm run start" C-m
tmux send-keys -t "$name:dev.3" "echo 'Run: npx react-native run-android'" C-m
tmux select-pane -t "$name:dev.1"

# agent
tmux new-window -t "$name:" -c "$path" -n agent "zsh -i -c x"

# logs
tmux new-window -t "$name:" -c "$path" -n logs "adb logcat -s Politis"

tmux select-window -t "$name:code"

[[ -z "$TMUX" ]] && exec tmux attach -t "$name"
exec tmux switch-client -t "$name"
