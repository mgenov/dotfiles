#!/usr/bin/env zsh
# wt — attach or create a Zellij session for a worktree.
#
# Usage:
#   wt              # interactive fzf picker
#   wt <name>       # attach or create session
#   wt ls           # list active sessions
#   wt kill <name>  # kill a session
#   wt kill-all     # kill all sessions

set -e

export PATH="$HOME/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH"

# ── Worktree registry ──────────────────────────────────────────────
# Add new entries here: name → directory
typeset -A worktrees
worktrees=(
  main    "$HOME/workspaces/idea/monorepo"
  a       "$HOME/workspaces/idea/monorepo-agent-a"
  b       "$HOME/workspaces/idea/monorepo-agent-b"
  mobile  "$HOME/workspaces/idea/monorepo-agent-c/politis/client/mobile"
  fleet   "$HOME/workspaces/infra/fleet-infra"
  cloud   "$HOME/workspaces/infra/cloud-infra"
)

# Session name: use the key directly (short, unique)
typeset -A session_names
session_names=(
  main  "main"
  a     "agent-a"
  b     "agent-b"
  mobile "agent-c"
  fleet "fleet"
  cloud "cloud"
)

# Layout per worktree (default: work)
typeset -A layouts
layouts=(
  mobile "mobile"
  fleet "infra"
  cloud "infra"
)

# ── Helpers ────────────────────────────────────────────────────────
_wt_list_entries() {
  for key in ${(ko)worktrees}; do
    printf "%-8s → %s\n" "$key" "${worktrees[$key]}"
  done
}

_wt_attach_or_create() {
  local key="$1"
  local dir="${worktrees[$key]}"
  local name="${session_names[$key]}"

  if [[ -z "$dir" ]]; then
    echo "unknown worktree: $key"
    echo ""
    _wt_list_entries
    exit 1
  fi

  if [[ ! -d "$dir" ]]; then
    echo "no such directory: $dir"
    exit 1
  fi

  cd "$dir"

  local layout="${layouts[$key]:-work}"

  if zellij list-sessions -s 2>/dev/null | grep -Fxq "$name"; then
    exec zellij attach "$name" --force-run-commands
  else
    exec zellij --session "$name" --new-session-with-layout "$layout"
  fi
}

# ── Main ───────────────────────────────────────────────────────────
case "$1" in
  ls)
    echo "Active sessions:"
    zellij list-sessions 2>/dev/null || echo "  (none)"
    echo ""
    echo "Registered worktrees:"
    _wt_list_entries
    ;;

  kill)
    if [[ -z "$2" ]]; then
      echo "Usage: wt kill <name>"
      exit 1
    fi
    local name="${session_names[$2]:-$2}"
    zellij kill-session "$name" 2>&1 && echo "killed: $name" || echo "no session: $name"
    ;;

  kill-all)
    zellij delete-all-sessions --force --yes 2>&1
    echo "all sessions killed"
    ;;

  -h|--help)
    echo "Usage: wt [<name>|ls|kill <name>|kill-all]"
    echo ""
    _wt_list_entries
    ;;

  "")
    # Interactive picker via fzf
    if ! command -v fzf &>/dev/null; then
      echo "Usage: wt <name>"
      echo ""
      _wt_list_entries
      exit 0
    fi

    local pick
    pick=$(_wt_list_entries | fzf --height=12 --reverse --prompt="worktree> " | awk '{print $1}')
    [[ -z "$pick" ]] && exit 0
    _wt_attach_or_create "$pick"
    ;;

  *)
    _wt_attach_or_create "$1"
    ;;
esac
