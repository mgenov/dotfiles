#!/usr/bin/env bash
# tm-infra — code / shell / agent windows (no logs tab).
# Usage:  cd ~/work/cloud-infra && tm-infra [<session-name>]
set -e

path="${2:-$PWD}"
name="${1:-$(basename "$path" | tr '. ' '__')}"

ensure_window() {
    local win="$1" cmd="$2"
    tmux list-windows -t "$name" -F '#W' 2>/dev/null | grep -Fxq "$win" && return
    tmux new-window -t "$name:" -c "$path" -n "$win" "$cmd"
}

if ! tmux has-session -t="$name" 2>/dev/null; then
    tmux new-session -ds "$name" -c "$path" -n code "nvim ."
fi

ensure_window code  "nvim ."
ensure_window shell "zsh"
ensure_window agent "zsh -i -c x"
tmux select-window -t "$name:code"

[[ -z "$TMUX" ]] && exec tmux attach -t "$name"
exec tmux switch-client -t "$name"
