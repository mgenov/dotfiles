#!/usr/bin/env sh

# Layout
yabai -m config layout bsp          # binary space partitioning (auto-tiles)

# Gaps
yabai -m config window_gap 10
yabai -m config top_padding 10
yabai -m config bottom_padding 10
yabai -m config left_padding 10
yabai -m config right_padding 10

# Focus follows mouse
yabai -m config focus_follows_mouse autofocus

# When a window is destroyed AND focus is lost, focus the most recently used window.
# The query guard prevents firing on transient system popups (e.g. input source HUD
# from Cmd+Space) which destroy themselves without ever taking focus — without it,
# the recent-focus action would yank focus to a random recent app.
yabai -m signal --add event=window_destroyed action="yabai -m query --windows --window >/dev/null 2>&1 || yabai -m window --focus recent 2>/dev/null"

# Don't tile these apps
yabai -m rule --add app="^System Preferences$" manage=off
yabai -m rule --add app="^Finder$" manage=off
yabai -m rule --add app="^Spotify$" manage=off   # floating; Cmd+H да го скриеш

# Title these apps
yabai -m rule --add app="^ghostty$" manage=on
yabai -m rule --add app="^Arc$" manage=on

# Android emulator: keep it FLOATING. The emulator renders into a hardware-
# accelerated Metal/OpenGL surface; when yabai manages it, every tile/move/
# resize repositions that GPU surface and it fails to repaint cleanly -> the
# partial flashing that only a show/hide (full redraw) clears. Floating means
# yabai never resizes/moves it, so it never flashes. Launch via `emu` (bin/emu).
yabai -m rule --add app="^qemu-system-aarch64$" manage=off

# JetBrains dialogs (Merge, Commit, Settings, Find, ...) are top-level Swing
# windows that report as AXStandardWindow — identical to the main editor — so
# yabai tiles them. They can't be told apart by app/role/subrole, only by title:
# editor windows always contain the " – " (en-dash) project/file separator; the
# transient dialogs never do. Float anything that isn't a main editor window.
yabai -m signal --add app="^(IntelliJ IDEA|Android Studio)$" event=window_created \
  action='yabai -m query --windows --window $YABAI_WINDOW_ID | jq -e "select(.title | test(\" – \") | not) | .id" >/dev/null 2>&1 && yabai -m window $YABAI_WINDOW_ID --toggle float'

# The signal above only sees windows created AFTER it registers. On a yabai
# restart, dialogs that are already open get re-tiled — so sweep them once on
# load: float any existing JetBrains window that isn't a main editor window.
yabai -m query --windows \
  | jq -r '.[] | select((.app|test("^(IntelliJ IDEA|Android Studio)$")) and (.["is-floating"]|not) and (.title|test(" – ")|not)) | .id' \
  | while read -r wid; do yabai -m window "$wid" --toggle float; done
